
set testfilename1 cookies.rvt

::tcltest::test cookies-1.1 {Cookies} \
    -setup {
        unset -nocomplain page
    } \
    -body {
        set page [::http::geturl "${urlbase}$testfilename1" -headers {Cookie "foo=bar"}]
        regexp -line {^cookies\(foo\) = bar$} [::http::data $page]
    } \
    -cleanup {
        if {[info exists page]} {
            ::http::cleanup $page
        }
        unset -nocomplain page
    } \
    -result 1

